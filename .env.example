# ─── Database ────────────────────────────────────────────────────────────────
POSTGRES_DB=c4p_social
POSTGRES_USER=c4p
POSTGRES_PASSWORD=changeme_strong_password

# ─── Ollama / LLM ────────────────────────────────────────────────────────────
OLLAMA_HOST=http://ollama:11434
# Options: deepseek-r1:14b  |  deepseek-r1:32b
LLM_MODEL=deepseek-r1:14b

# ─── Scraper ─────────────────────────────────────────────────────────────────
# Comma-separated public Instagram usernames to monitor
INSTAGRAM_TARGETS=natgeo,nasa,bbcnews
# Comma-separated YouTube / generic gallery-dl targets (full URLs or channel IDs)
GALLERY_DL_TARGETS=https://www.youtube.com/@veritasium

# Scrape interval in seconds (default 21600 = 6 hours)
SCRAPE_INTERVAL=21600

# ─── Email Digest (MWF) ──────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASSWORD=your_app_password
DIGEST_FROM=your@gmail.com
# Comma-separated recipient list
DIGEST_TO=team@computers4people.org
# Cron for MWF 8 AM: "0 8 * * 1,3,5"
DIGEST_CRON=0 8 * * 1,3,5

# ─── Postiz ──────────────────────────────────────────────────────────────────
POSTIZ_SECRET=changeme_32char_random_string_here
POSTIZ_FRONTEND_URL=http://localhost:5000
NEXT_PUBLIC_BACKEND_URL=http://localhost:3000

# ─── Transparency ─────────────────────────────────────────────────────────────
# All AI-generated content is flagged automatically. Set to "strict" to require
# human approval before content reaches scheduling queue.
AI_AUDIT_MODE=strict
