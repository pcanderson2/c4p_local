#!/bin/bash
set -e

INSTALL_DIR="/opt/c4p-social"
SERVICE_NAME="c4p-social"
LOG="/var/log/c4p-social-install.log"

log() { echo "[c4p-social] $1" | tee -a "$LOG"; }

log "=== C4P Social Monitor post-install starting ==="

# NOTE: This script NEVER calls apt-get, apt, or any installer that calls them
# (including get.docker.com). The dpkg/apt lock is held by the parent process
# for the entire duration of postinst. All such installs are deferred to helper
# scripts that the user runs after this package finishes configuring.

# ── 1. Write helper scripts ───────────────────────────────────────────────────

# c4p-install-docker — installs Docker Engine + Compose (safe to run after dpkg exits)
cat > /usr/local/bin/c4p-install-docker << 'DOCKEREOF'
#!/bin/bash
set -e
echo "[c4p-docker] Installing Docker Engine..."
curl -fsSL https://get.docker.com | sh
systemctl enable docker
systemctl start docker
echo "[c4p-docker] Installing Docker Compose plugin..."
COMPOSE_URL="https://github.com/docker/compose/releases/latest/download/docker-compose-linux-x86_64"
mkdir -p /usr/local/lib/docker/cli-plugins
curl -fsSL "$COMPOSE_URL" -o /usr/local/lib/docker/cli-plugins/docker-compose
chmod +x /usr/local/lib/docker/cli-plugins/docker-compose
if [ -n "$SUDO_USER" ]; then
    usermod -aG docker "$SUDO_USER"
    echo "[c4p-docker] Added $SUDO_USER to docker group. Log out and back in for it to take effect."
fi
echo "[c4p-docker] Docker ready. Now run: sudo systemctl start c4p-social"
DOCKEREOF
chmod +x /usr/local/bin/c4p-install-docker

# c4p-install-gpu — installs NVIDIA drivers + container toolkit
cat > /usr/local/bin/c4p-install-gpu << 'GPUEOF'
#!/bin/bash
set -e
UBUNTU_VER=$(lsb_release -rs)
if [[ "$UBUNTU_VER" == "24.04" ]]; then
    DRIVER_PKG="nvidia-driver-550"
else
    DRIVER_PKG="nvidia-driver-535"
fi
echo "[c4p-gpu] Installing $DRIVER_PKG..."
apt-get update -qq
apt-get install -y "$DRIVER_PKG"
echo "[c4p-gpu] Installing NVIDIA Container Toolkit..."
curl -fsSL https://nvidia.github.io/libnvidia-container/gpgkey \
    | gpg --dearmor -o /usr/share/keyrings/nvidia-container-toolkit-keyring.gpg
curl -s -L https://nvidia.github.io/libnvidia-container/stable/deb/nvidia-container-toolkit.list \
    | sed 's#deb https://#deb [signed-by=/usr/share/keyrings/nvidia-container-toolkit-keyring.gpg] https://#g' \
    | tee /etc/apt/sources.list.d/nvidia-container-toolkit.list
apt-get update -qq
apt-get install -y nvidia-container-toolkit
nvidia-ctk runtime configure --runtime=docker
systemctl restart docker
echo "[c4p-gpu] Done. Please reboot, then run: sudo systemctl start c4p-social"
GPUEOF
chmod +x /usr/local/bin/c4p-install-gpu

log "Helper scripts written: c4p-install-docker, c4p-install-gpu"

# ── 2. Docker Compose plugin (no apt — direct binary download) ────────────────
if command -v docker &>/dev/null; then
    log "Docker already installed: $(docker --version)"
    if [ -n "$SUDO_USER" ]; then
        usermod -aG docker "$SUDO_USER" 2>/dev/null || true
        log "Added $SUDO_USER to docker group."
    fi
    if ! docker compose version &>/dev/null; then
        log "Installing Docker Compose plugin..."
        COMPOSE_URL="https://github.com/docker/compose/releases/latest/download/docker-compose-linux-x86_64"
        mkdir -p /usr/local/lib/docker/cli-plugins
        curl -fsSL "$COMPOSE_URL" -o /usr/local/lib/docker/cli-plugins/docker-compose
        chmod +x /usr/local/lib/docker/cli-plugins/docker-compose
        log "Docker Compose installed: $(docker compose version)"
    else
        log "Docker Compose already installed: $(docker compose version)"
    fi
else
    log "Docker not found — will need to be installed before starting the stack."
fi

# ── 3. NVIDIA — detect and advise only (no apt) ───────────────────────────────
if lspci 2>/dev/null | grep -qi nvidia; then
    log "NVIDIA GPU detected."
    if ! command -v nvidia-smi &>/dev/null || ! dpkg -s nvidia-container-toolkit &>/dev/null 2>/dev/null; then
        log "NVIDIA drivers or container toolkit not fully installed."
    else
        log "NVIDIA drivers and toolkit already installed."
    fi
else
    log "No NVIDIA GPU detected — removing GPU block from docker-compose.yml..."
    python3 - <<'PYEOF'
import re, os
path = "/opt/c4p-social/docker-compose.yml"
if not os.path.exists(path):
    print("docker-compose.yml not found, skipping.")
    exit(0)
with open(path) as f:
    content = f.read()
content = re.sub(
    r'    deploy:\n      resources:\n        reservations:\n          devices:\n            - driver: nvidia\n              count: all\n              capabilities: \[gpu\]\n',
    '',
    content
)
with open(path, "w") as f:
    f.write(content)
print("GPU block removed.")
PYEOF
fi

# ── 4. Fix line endings ───────────────────────────────────────────────────────
log "Fixing line endings..."
find "$INSTALL_DIR" -name "*.py" -o -name "*.sh" -o -name "*.sql" | xargs dos2unix -q 2>/dev/null || true

# ── 5. Set up .env ────────────────────────────────────────────────────────────
if [ -f "$INSTALL_DIR/.env" ]; then
    log ".env is pre-configured and ready."
else
    cp "$INSTALL_DIR/.env.example" "$INSTALL_DIR/.env"
    log "Created .env from template — edit before starting."
fi

# ── 6. Set permissions ────────────────────────────────────────────────────────
chmod 600 "$INSTALL_DIR/.env"
if [ -n "$SUDO_USER" ]; then
    chown -R "$SUDO_USER:$SUDO_USER" "$INSTALL_DIR"
fi

# ── 7. Install systemd service ────────────────────────────────────────────────
log "Installing systemd service..."
cat > /etc/systemd/system/${SERVICE_NAME}.service <<EOF
[Unit]
Description=C4P Social Media Monitor
Documentation=https://github.com/pcanderson2/c4p_local
After=docker.service network-online.target
Requires=docker.service

[Service]
Type=oneshot
RemainAfterExit=yes
WorkingDirectory=${INSTALL_DIR}
ExecStart=/usr/bin/docker compose up -d
ExecStop=/usr/bin/docker compose down
TimeoutStartSec=300
User=${SUDO_USER:-root}

[Install]
WantedBy=multi-user.target
EOF

systemctl daemon-reload
systemctl enable ${SERVICE_NAME}
log "Systemd service installed and enabled."

# ── 8. Start stack (only if Docker is available) ──────────────────────────────
if command -v docker &>/dev/null; then
    log "Building Docker images and starting stack..."
    cd "$INSTALL_DIR"
    if [ -n "$SUDO_USER" ]; then
        sudo -u "$SUDO_USER" docker compose up -d --build 2>&1 | tee -a "$LOG"
    else
        docker compose up -d --build 2>&1 | tee -a "$LOG"
    fi

    # ── 9. Pull Ollama model ──────────────────────────────────────────────────
    LLM_MODEL=$(grep LLM_MODEL "$INSTALL_DIR/.env" | cut -d= -f2 | tr -d ' ')
    LLM_MODEL="${LLM_MODEL:-deepseek-r1:14b}"
    log "Pulling Ollama model: $LLM_MODEL (this may take several minutes)..."
    for i in $(seq 1 30); do
        if curl -sf http://localhost:11434/api/tags &>/dev/null; then break; fi
        sleep 5
    done
    if [ -n "$SUDO_USER" ]; then
        sudo -u "$SUDO_USER" docker compose exec -T ollama ollama pull "$LLM_MODEL" 2>&1 | tee -a "$LOG" || \
            log "WARNING: Model pull failed — run 'docker compose exec ollama ollama pull $LLM_MODEL' manually."
    else
        docker compose exec -T ollama ollama pull "$LLM_MODEL" 2>&1 | tee -a "$LOG" || \
            log "WARNING: Model pull failed — run 'docker compose exec ollama ollama pull $LLM_MODEL' manually."
    fi
fi

# ── Done ──────────────────────────────────────────────────────────────────────
log ""
log "=== Installation complete ==="
log ""
if ! command -v docker &>/dev/null; then
log "  NEXT STEP: Docker is not installed. Run:"
log "    sudo c4p-install-docker"
log "  Then start the stack:"
log "    sudo systemctl start c4p-social"
else
log "  Postiz dashboard  ->  http://localhost:5000"
log "  Ollama API        ->  http://localhost:11434"
log "  Mailpit inbox     ->  http://localhost:8025 (if enabled)"
fi
if lspci 2>/dev/null | grep -qi nvidia && ! command -v nvidia-smi &>/dev/null; then
log ""
log "  NEXT STEP: NVIDIA GPU found but drivers missing. Run:"
log "    sudo c4p-install-gpu"
fi
log ""
log "  Full install log: $LOG"
